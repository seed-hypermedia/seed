{
  "name": "@seed-hypermedia/agents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/main.ts",
    "build": "NODE_ENV=production bun build.ts",
    "test:build": "bun run build && bun scripts/smoke-build.ts",
    "test:docker": "bun scripts/smoke-docker.ts",
    "typecheck": "bun tsgo --noEmit",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "check": "conc 'bun typecheck' 'bun format:write'"
  },
  "overrides": {
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "@seed-hypermedia/client": "file:../frontend/packages/client"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "0.70.2",
    "@seed-hypermedia/agents-protocol": "file:./protocol",
    "@seed-hypermedia/client": "file:../frontend/packages/client",
    "@shm/shared": "file:../frontend/packages/shared",
    "bun-plugin-tailwind": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.545.0",
    "multiformats": "^13.4.1",
    "react": "^19",
    "react-dom": "^19",
    "react-router-dom": "^7.13.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.11",
    "tw-animate-css": "^1.4.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript/native-preview": "^7.0.0-dev.20260224.1",
    "concurrently": "^9.2.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.13",
    "superjson": "2.2.1"
  }
}
