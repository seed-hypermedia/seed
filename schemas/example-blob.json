{
  "name": "Blob",
  "description": "A binary payload tagged with a MIME type and optional size.",
  "type": "hm://hyper.media/map",
  "required": [
    "mime",
    "data"
  ],
  "properties": {
    "mime": {
      "ref": "hm://hyper.media/string"
    },
    "size": {
      "ref": "hm://hyper.media/integer"
    },
    "data": {
      "ref": "hm://hyper.media/bytes"
    }
  }
}
