{
  "name": "Scalar schema",
  "description": "The variant for a scalar value (null, boolean, integer, float, string, bytes), optionally restricted by enum.",
  "type": "hm://hyper.media/map",
  "required": [
    "type"
  ],
  "properties": {
    "type": {
      "type": "hm://hyper.media/string",
      "enum": [
        "hm://hyper.media/null",
        "hm://hyper.media/boolean",
        "hm://hyper.media/integer",
        "hm://hyper.media/float",
        "hm://hyper.media/string",
        "hm://hyper.media/bytes"
      ]
    },
    "enum": {
      "type": "hm://hyper.media/list"
    },
    "name": {
      "type": "hm://hyper.media/string"
    },
    "description": {
      "type": "hm://hyper.media/string"
    }
  }
}
