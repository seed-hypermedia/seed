{
  "name": "Person",
  "description": "A person with a name, age, active flag, home address, and nicknames.",
  "type": "hm://hyper.media/map",
  "required": [
    "name"
  ],
  "properties": {
    "name": {
      "ref": "hm://hyper.media/string"
    },
    "age": {
      "ref": "hm://hyper.media/integer"
    },
    "active": {
      "ref": "hm://hyper.media/boolean"
    },
    "home": {
      "ref": "hm://example.com/address"
    },
    "nicknames": {
      "type": "hm://hyper.media/list",
      "items": {
        "ref": "hm://hyper.media/string"
      }
    }
  }
}
