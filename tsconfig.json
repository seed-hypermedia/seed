{
  // NOTE: Do NOT set "preserveSymlinks": true here.
  // pnpm uses symlinks for node_modules resolution. Enabling preserveSymlinks
  // causes TypeScript to fail to resolve type dependencies correctly.
  // See https://pnpm.io/typescript#do-not-preserve-symlinks
  "compilerOptions": {
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@shm/ui/*": ["./frontend/packages/ui/src/*"],
      "@shm/shared": ["./frontend/packages/shared/src/index.ts"],
      "@shm/shared/*": ["./frontend/packages/shared/src/*"],
      "@shm/editor/*": ["./frontend/packages/editor/src/*"]
    },
    "plugins": []
  }
}
