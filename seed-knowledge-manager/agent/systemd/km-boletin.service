[Unit]
Description=Knowledge Manager — weekly bulletin (boletín periódico)
After=default.target

[Service]
Type=oneshot
EnvironmentFile=/home/km/.nanobot/secrets.env
Environment=PATH=/home/km/.local/bin:/usr/bin:/usr/local/bin
Environment=KM_TASK=boletin
Environment=KM_TRIGGER=cadence-boletin
Environment=SEED_CLI_PATH=/home/km/.local/bin/seed-cli
Environment=KM_STATE_DIR=/home/km/km-state
Environment=KM_LOGS_DIR=/home/km/km-logs
ExecStart=/usr/bin/node /home/km/km-agent/mcp/seed-cli-mcp/dist/cadence-cli.js
TimeoutStartSec=300

[Install]
WantedBy=default.target
