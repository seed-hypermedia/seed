{
  "name": "@seed-hypermedia/client",
  "version": "0.0.1",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      },
      "./*": {
        "import": "./dist/*.js",
        "types": "./dist/*.d.ts"
      }
    }
  },
  "scripts": {
    "build": "tsup && tsc --project tsconfig.build.json",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "prepublishOnly": "pnpm build",
    "test": "vitest --run",
    "typecheck": "tsc --noEmit --project tsconfig.app.json"
  },
  "dependencies": {
    "@ipld/dag-cbor": "^9.2.5",
    "multiformats": "^13.4.1",
    "superjson": "2.2.1"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "5.8.3",
    "vitest": "0.34.2",
    "zod": "3.25.76"
  },
  "peerDependencies": {
    "zod": ">=3.20.0"
  }
}
